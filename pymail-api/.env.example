# Sender grouping mode for source_key generation
# false = provider grouping (myblog.github.io -> github)
# true = tenant grouping (myblog.github.io -> myblog)
NORMALIZE_SOURCE_INCLUDE_PRIVATE_DOMAINS=false

# CORS origins allowed by the API (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8008

# Optional VirusTotal integration (leave empty to disable)
VIRUSTOTAL_API_KEY=

# Optional domain reputation cache settings
DOMAIN_REPUTATION_CACHE_FILE=domain_reputation_cache.json
DOMAIN_REPUTATION_DNS_TTL_SECONDS=21600
DOMAIN_REPUTATION_VT_TTL_SECONDS=21600
